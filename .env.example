# Copy this file to .env.local for local development.
# On Vercel: set these as Environment Variables in the project settings.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Found in: Google AI Studio → API Keys
# On Vercel this must be named GEMINI_API_KEY (not VITE_ prefixed — it is
# injected at build time via vite.config.ts define block).
GEMINI_API_KEY=your-gemini-api-key-here
